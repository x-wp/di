{
  "name": "x-wp/di",
  "description": "The dependency injection container for WordPress",
  "license": "GPL-2.0-only",
  "type": "library",
  "keywords": [
    "wordpress",
    "hooks",
    "actions",
    "filters",
    "dependency-injection",
    "di"
  ],
  "readme": "README.md",
  "authors": [
    {
      "name": "Sibin Grasic",
      "email": "sibin.grasic@oblak.studio",
      "homepage": "https://sib.ing",
      "role": "Author"
    }
  ],
  "support": {
    "source": "https://github.com/x-wp",
    "issues": "https://github.com/x-wp/di/issues",
    "email": "podrska@oblak.studio"
  },
  "require": {
    "php": ">=8.1 <8.5",
    "automattic/jetpack-constants": "^2 || ^3",
    "php-di/php-di": "^7.1",
    "x-wp/helper-classes": "^1.13",
    "x-wp/helper-functions": "^1.13"
  },
  "require-dev": {
    "automattic/jetpack-autoloader": "*",
    "oblak/wordpress-coding-standard": "^1.1",
    "php-stubs/woocommerce-stubs": "^9.5",
    "php-stubs/wordpress-stubs": "^6.6",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^1.12",
    "phpstan/phpstan-deprecation-rules": "^1.2",
    "phpunit/phpunit": "^9.6",
    "swissspidy/phpstan-no-private": "^0.2",
    "symfony/polyfill-php82": "^1.31",
    "symfony/var-dumper": "^5.4",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "wp-cli/wp-cli": "^2.11",
    "x-wp/whoops": "^1.1",
    "yoast/phpunit-polyfills": "^1.1"
  },
  "conflict": {
    "oblak/wp-hook-di": "*"
  },
  "provide": {
    "psr/container-implementation": "1.1 || 2.0",
    "x-wp/di-implementation": "self.version"
  },
  "suggest": {
    "automattic/jetpack-autoloader": "Allow for better interoperability with other plugins that use this package."
  },
  "scripts": {
    "phpcs": "phpcs --standard=phpcs.xml",
    "phpstan": "phpstan analyse --memory-limit=512M",
    "test": "@test:unit",
    "test:unit": "phpunit --configuration phpunit.xml.dist --testsuite unit"
  },
  "autoload-dev": {
    "XWP\\DI\\T\\": "tests/fixtures/shared/"
  },
  "autoload": {
    "psr-4": {
      "XWP\\DI\\": "src/"
    },
    "classmap": [
      "src/Core/"
    ],
    "files": [
      "src/Functions/xwp-di-definition-fns.php",
      "src/Functions/xwp-di-container-fns.php",
      "src/Functions/xwp-di-helper-fns.php"
    ]
  },
  "config": {
    "allow-plugins": {
      "automattic/jetpack-autoloader": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true
    },
    "sort-packages": true
  }
}
